<script async type="text/javascript" defer="defer" is:inline>
    const typedTextSpan = document.querySelector(".intro");
    const cursor = document.querySelector(".cursor");
    const typedText = document.querySelector(".moto");
    const cursor2 = document.querySelector(".cursor2");

    const textArray = ["Gerrard Machinery Company"];
    const titleArray = ["Buyer's and Sellers of Industrial Machinery and Equipment"];
    const typingDelay = 70;

    let textArrayIndex = 0;
    let charIndex = 0;

    let titleArrayIndex = 0;
    let charIndex2 = 0;

    function type() {
	    if(charIndex < textArray[textArrayIndex].length) {
	    	if(!cursor.classList.contains("typing")) cursor.classList.add("typing");
		    typedTextSpan.textContent += textArray[textArrayIndex].charAt(charIndex);
		    charIndex++
		    setTimeout(type, typingDelay);
	    }
	    else {
		    cursor.classList.remove("typing");
	    }
    }

    function typer() {
	    if(charIndex2 < titleArray[titleArrayIndex].length) {
	    	if(!cursor2.classList.contains("typing")) cursor2.classList.add("typing");
	    	typedText.textContent += titleArray[titleArrayIndex].charAt(charIndex2);
		    charIndex2++
		    setTimeout(typer, typingDelay);
	    }
	    else {
	    	cursor2.classList.remove("typing");
	    }
    }

    document.addEventListener("DOMContentLoaded", function() {
	    typedTextSpan.textContent = "";
	    if(textArray.length) setTimeout(type, typingDelay + 250);
	    if(titleArray.length) setTimeout(typer, typingDelay + 3700);
    });
</script>