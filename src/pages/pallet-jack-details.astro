---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides5 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout title="Pallet Jacks - SOLD | Gerrard Group Inc"
    description="These warehouse pallet jacks have been sold. Browse our current surplus equipment inventory for available industrial machinery and warehouse equipment."
    canon="https://gerrardgroupinc.com/pallet-jack-details/"
    jsonLdType="product"
    jsonLdData={{
        name: "Warehouse Pallet Jacks",
        description: "Warehouse pallet jacks - previously available through Gerrard Group Inc",
        brand: "Various",
        category: "Warehouse Equipment",
        price: "0",
        sold: true,
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/pallet-jack-1.png"
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/pallet-jack-1.png"
    ogImageAlt="Warehouse Pallet Jacks - Sold - Gerrard Group"
    >
    <Directory
        title="Pallet Jacks"
        page="Jacks"
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-sold-layout">
                <Carousel client:load data={slides5} />
                <span class="pd-sold-badge">Sold</span>
                <p class="pd-sold-text">This item has been sold. Browse our <a href="/liquidations/">current inventory</a> for available equipment.</p>
            </div>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
