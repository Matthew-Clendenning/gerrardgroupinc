---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides10 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="Sullair 900/1150 Portable Air Compressor for Sale | Gerrard"
    description="Used 2018 Sullair Model 900/1150 high-pressure diesel portable air compressor with only 1,601 hours. 1150 ACCFM at 350 PSI. Cat diesel engine. Sale price $199,000."
    canon="https://gerrardgroupinc.com/sullair-air-compressor-900/"
    jsonLdType="product"
    jsonLdData={{
        name: "Sullair Model 900/1150 Portable Air Compressor",
        description: "2018 Sullair Model 900/1150 High Pressure Diesel Portable Air Compressor, 1150 ACCFM at 350 PSI, Cat Diesel Engine, only 1601 hours",
        brand: "Sullair",
        category: "Portable Air Compressors",
        price: "199000",
        sku: "900-1150-XHADTQ",
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/sullair-900-1.jpg",
        faq: [
            { question: "What is the Sullair 900/1150 air compressor used for?", answer: "The Sullair 900/1150 is a high-pressure portable diesel air compressor used for pipeline testing, well drilling, water well service, sandblasting, and mining operations. Its 1150 ACCFM at 350 PSI output delivers powerful air supply for demanding field applications." },
            { question: "How does the Sullair 900/1150 compare to Atlas Copco models?", answer: "The Sullair 900/1150 delivers 1150 ACCFM at 350 PSI, slightly lower volume than the Atlas Copco XRVS 1550 models (1544 CFM at 365 PSI) but at a comparable pressure. Sullair is known for robust rotary screw compressor technology and straightforward serviceability." },
            { question: "How many hours does this Sullair compressor have?", answer: "This 2018 Sullair Model 900/1150XHADTQ has only 1,601 hours, making it a low-hour unit. It features a Cat diesel engine, 249-gallon fuel tank, after cooler, water separator, and electric block heater." },
            { question: "Can this compressor be towed on the highway?", answer: "Yes. It is mounted on a tandem axle frame with electric brakes, designed for highway towing. The unit weighs approximately 16,040 lbs (7,276 kg)." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/sullair-900-1.jpg"
    ogImageAlt="Used Sullair 900/1150 Portable Air Compressor for Sale - Gerrard Group"
    >
    <Directory
        title="Sullair Model 900/1150 Portable Air Compressor"
        page=""
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides10} />
                <article class="pd-info">
                    <h2 class="pd-info__title">Sullair Model 900/1150 High Pressure Diesel Portable Air Compressor</h2>
                    <p class="pd-info__model">Model: <strong>900/1150XHADTQ</strong> — New 2018 (Only 1,601 Hours)</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Capacity</span>
                            <span class="pd-spec__value">1150 ACCFM @ 350 PSI (Rated)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Fuel Capacity</span>
                            <span class="pd-spec__value">249 Gallon</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Frame</span>
                            <span class="pd-spec__value">Tandem Axle with Electric Brakes</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Equipped With</span>
                            <span class="pd-spec__value">Cat Diesel Engine, After Cooler, Water Separator, Electric Block Heater</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">16,040 LB / 7,276 Kg</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__original">$269,000.00</p>
                        <p class="pd-pricing__sale">$199,000.00</p>
                        <p class="pd-pricing__label">Special Sale Price</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the Sullair 900/1150 air compressor used for?</p>
                    <p class="pd-faq__answer">The Sullair 900/1150 is a high-pressure portable diesel air compressor used for pipeline testing, well drilling, water well service, sandblasting, and mining operations. Its 1150 ACCFM at 350 PSI output delivers powerful air supply for demanding field applications.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How does the Sullair 900/1150 compare to Atlas Copco models?</p>
                    <p class="pd-faq__answer">The Sullair 900/1150 delivers 1150 ACCFM at 350 PSI, slightly lower volume than the Atlas Copco XRVS 1550 models (1544 CFM at 365 PSI) but at a comparable pressure. Sullair is known for robust rotary screw compressor technology and straightforward serviceability.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How many hours does this Sullair compressor have?</p>
                    <p class="pd-faq__answer">This 2018 Sullair Model 900/1150XHADTQ has only 1,601 hours, making it a low-hour unit. It features a Cat diesel engine, 249-gallon fuel tank, after cooler, water separator, and electric block heater.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Can this compressor be towed on the highway?</p>
                    <p class="pd-faq__answer">Yes. It is mounted on a tandem axle frame with electric brakes, designed for highway towing. The unit weighs approximately 16,040 lbs (7,276 kg).</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/atlas-copco-air-compressor-1550-cd/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XRVS 1550 CD Air Compressor
                    </a>
                    <a href="/atlas-copco-air-compressor-1550-cd7/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XRVS 1550 CD7 Air Compressor
                    </a>
                    <a href="/atlas-copco-air-compressor-1600/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XAS 1600 CD6 Air Compressor
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
