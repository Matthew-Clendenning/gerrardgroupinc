---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides9 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="Atlas Copco XRVS 1550 CD7 Air Compressor for Sale | Gerrard"
    description="Used 2016 Atlas Copco XRVS 1550 CD7 high-pressure diesel portable air compressor. 1544 CFM at 363 PSI, Cat diesel engine, only 1,415 hours. Sale price $219,000."
    canon="https://gerrardgroupinc.com/atlas-copco-air-compressor-1550-cd7/"
    jsonLdType="product"
    jsonLdData={{
        name: "Atlas Copco XRVS 1550 CD7 Portable Air Compressor",
        description: "2016 Atlas Copco XRVS 1550 CD7 High Pressure Diesel Portable Air Compressor, 1544 CFM at 363 PSI, Cat Diesel Engine, only 1415 hours",
        brand: "Atlas Copco",
        category: "Portable Air Compressors",
        price: "219000",
        sku: "XRVS-1550-CD7",
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/atlas-copco-1550-1.jpg",
        faq: [
            { question: "What is the difference between the Atlas Copco XRVS 1550 CD and CD7?", answer: "The CD7 is the newer generation model (2016 vs. 2014 for the CD). Both deliver 1544 CFM at similar pressures (363 PSI for CD7 vs. 365 PSI for CD), but the CD7 features updated T2 emissions compliance. This particular CD7 unit has fewer hours (1,415 vs. 1,942)." },
            { question: "What applications is the XRVS 1550 CD7 suited for?", answer: "The Atlas Copco XRVS 1550 CD7 is a high-pressure portable air compressor suited for pipeline testing, well service, sandblasting, mining, and large-scale industrial construction where high CFM and PSI output are required on remote jobsites." },
            { question: "How many hours does this unit have?", answer: "This 2016 Atlas Copco XRVS 1550 CD7 has only 1,415 hours. It is powered by a Cat diesel engine with a 240-gallon fuel tank, after cooler, water separator, and electric block heater." },
            { question: "Is this compressor highway towable?", answer: "Yes. It is mounted on a tandem axle frame with electric brakes, designed for highway towing. The GVWR is 8,095 kg and GAWR is 9,070 kg." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/atlas-copco-1550-1.jpg"
    ogImageAlt="Used Atlas Copco XRVS 1550 CD7 Portable Air Compressor for Sale - Gerrard Group"
    >
    <Directory
        title="Atlas Copco XRVS 1550 CD7 Portable Air Compressor"
        page=""
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides9} />
                <article class="pd-info">
                    <h2 class="pd-info__title">Atlas Copco XRVS 1550 CD7 High Pressure Diesel Portable Air Compressor</h2>
                    <p class="pd-info__model">Model: <strong>XRVS 1550 CD7 T2 TANDEM EB AFT</strong> — New 2016 (Only 1,415 Hours)</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Capacity</span>
                            <span class="pd-spec__value">1544 CFM @ 363 PSI (Norm.)<br>1350 CFM @ 506 PSI (Max.)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Fuel Capacity</span>
                            <span class="pd-spec__value">240 Gallon</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Frame</span>
                            <span class="pd-spec__value">Tandem Axle with Electric Brakes</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Equipped With</span>
                            <span class="pd-spec__value">Cat Diesel Engine, After Cooler, Water Separator, Electric Block Heater</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">GVWR: 8,095 Kg<br>GAWR: 9,070 Kg</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__original">$289,000.00</p>
                        <p class="pd-pricing__sale">$219,000.00</p>
                        <p class="pd-pricing__label">Special Sale Price</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the difference between the Atlas Copco XRVS 1550 CD and CD7?</p>
                    <p class="pd-faq__answer">The CD7 is the newer generation model (2016 vs. 2014 for the CD). Both deliver 1544 CFM at similar pressures (363 PSI for CD7 vs. 365 PSI for CD), but the CD7 features updated T2 emissions compliance. This particular CD7 unit has fewer hours (1,415 vs. 1,942).</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What applications is the XRVS 1550 CD7 suited for?</p>
                    <p class="pd-faq__answer">The Atlas Copco XRVS 1550 CD7 is a high-pressure portable air compressor suited for pipeline testing, well service, sandblasting, mining, and large-scale industrial construction where high CFM and PSI output are required on remote jobsites.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How many hours does this unit have?</p>
                    <p class="pd-faq__answer">This 2016 Atlas Copco XRVS 1550 CD7 has only 1,415 hours. It is powered by a Cat diesel engine with a 240-gallon fuel tank, after cooler, water separator, and electric block heater.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Is this compressor highway towable?</p>
                    <p class="pd-faq__answer">Yes. It is mounted on a tandem axle frame with electric brakes, designed for highway towing. The GVWR is 8,095 kg and GAWR is 9,070 kg.</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/atlas-copco-air-compressor-1550-cd/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XRVS 1550 CD Air Compressor
                    </a>
                    <a href="/atlas-copco-air-compressor-1600/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XAS 1600 CD6 Air Compressor
                    </a>
                    <a href="/sullair-air-compressor-900/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Sullair 900/1150 Air Compressor
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
