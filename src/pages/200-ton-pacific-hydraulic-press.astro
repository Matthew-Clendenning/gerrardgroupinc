---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="200 Ton Pacific Hydraulic Press for Sale | Gerrard Group"
    description="Used 200-ton Pacific Model 200-D-10-36 downstroke hydraulic press. Gib guided, dual cylinder, T-slotted bed, Allen Bradley PLC controls. Contact for pricing."
    canon="https://gerrardgroupinc.com/200-ton-pacific-hydraulic-press/"
    jsonLdType="product"
    jsonLdData={{
        name: "200 Ton Pacific Model 200-D-10-36 Hydraulic Press",
        description: "Pacific Model 200-D-10-36 Downstroke Self Contained Hydraulic Press, 200 Ton capacity, Gib Guided, Dual Cylinder, T-Slotted Bed and Slide, Allen Bradley PLC",
        brand: "Pacific",
        category: "Hydraulic Presses",
        price: "0",
        sku: "200-D-10-36-8380",
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/200-ton-pacific-press-1.JPG"
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/200-ton-pacific-press-1.JPG"
    ogImageAlt="Used 200 Ton Pacific Hydraulic Press for Sale - Gerrard Group"
    >
    <Directory
        title="200 Ton Pacific Model Hydraulic Press"
        page="Hydraulic Presses"
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides} />
                <article class="pd-info">
                    <h2 class="pd-info__title">200 Ton Pacific Model 200-D-10-36 Downstroke Self Contained Hydraulic Press</h2>
                    <p class="pd-info__model">Serial No.: <strong>8380 (1978)</strong> — Gib Guided, Dual Cylinder, T-Slotted Bed and Slide</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Bed Area (Nominal)</span>
                            <span class="pd-spec__value">123" L-R x 36" F-B (T-Slotted F-B)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Slide Area (Nominal)</span>
                            <span class="pd-spec__value">123" L-R x 36" F-B (T-Slotted F-B)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Dist. Between Housings</span>
                            <span class="pd-spec__value">L-R</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Stroke of Gib Guided Slide</span>
                            <span class="pd-spec__value">0" — 18" Max.</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Daylight Opening</span>
                            <span class="pd-spec__value">30" Max.</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Max. Upper Die Weight</span>
                            <span class="pd-spec__value">10,000 lbs</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Speeds Approx.</span>
                            <span class="pd-spec__value">187 IPM Fast Closing</span>
                        </div>
                        <div class="pd-spec-sub">
                            <span class="pd-spec-sub__value">89 IPM Slow Close</span>
                            <span class="pd-spec-sub__value">34 IPM Pressing</span>
                            <span class="pd-spec-sub__value">70 IPM Slow Return</span>
                            <span class="pd-spec-sub__value">176 IPM Fast Return</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Power Unit (Top Rear)</span>
                            <span class="pd-spec__value">30 HP 460/3/60 Motor Driving Hydraulic Unit</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">43,000 lbs</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Physical Dimensions</span>
                            <span class="pd-spec__value">13' L-R x 5' F-B x 26' H</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Controls</span>
                            <span class="pd-spec__value">Push Button Operation with Stroke, Pressure and Speed Control. Allen Bradley PLC Added in 2000. Light Curtains.</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__contact">Contact for Pricing</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
