---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="200 Ton Pacific Hydraulic Press for Sale | Gerrard Group"
    description="Used 200-ton Pacific Model 200-D-10-36 downstroke hydraulic press. Gib guided, dual cylinder, T-slotted bed, Allen Bradley PLC controls. Contact for pricing."
    canon="https://gerrardgroupinc.com/200-ton-pacific-hydraulic-press/"
    jsonLdType="product"
    jsonLdData={{
        name: "200 Ton Pacific Model 200-D-10-36 Hydraulic Press",
        description: "Pacific Model 200-D-10-36 Downstroke Self Contained Hydraulic Press, 200 Ton capacity, Gib Guided, Dual Cylinder, T-Slotted Bed and Slide, Allen Bradley PLC",
        brand: "Pacific",
        category: "Hydraulic Presses",
        price: "0",
        sku: "200-D-10-36-8380",
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/200-ton-pacific-press-1.JPG",
        faq: [
            { question: "What is a 200 ton hydraulic press used for?", answer: "A 200 ton hydraulic press is used for forming, bending, stamping, punching, and assembly operations across manufacturing industries. The Pacific 200-D series is commonly found in automotive, aerospace, appliance, and general metal fabrication shops for medium-duty pressing applications." },
            { question: "What condition is this used Pacific 200-D-10-36 hydraulic press in?", answer: "This Pacific Model 200-D-10-36 was manufactured in 1978 (Serial No. 8380). It is a gib guided, dual cylinder press with T-slotted bed and slide. The Allen Bradley PLC controls were upgraded in 2000, and light curtains have been added for operator safety." },
            { question: "What are the main specifications of this 200 ton press?", answer: "This press features a 123\" x 36\" T-slotted bed area, 30\" maximum daylight opening, 18\" maximum stroke, 34 IPM pressing speed, a 30 HP hydraulic power unit, and weighs approximately 43,000 lbs. Overall dimensions are 13' L-R x 5' F-B x 26' H." },
            { question: "Does Gerrard Group offer shipping and installation?", answer: "Yes. Gerrard Group Inc provides full rigging, transportation, and installation services for heavy industrial equipment across the United States, Mexico, and Canada. Contact us at (847) 894-3434 for a quote." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/200-ton-pacific-press-1.JPG"
    ogImageAlt="Used 200 Ton Pacific Hydraulic Press for Sale - Gerrard Group"
    >
    <Directory
        title="200 Ton Pacific Model Hydraulic Press"
        page="Hydraulic Presses"
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides} />
                <article class="pd-info">
                    <h2 class="pd-info__title">200 Ton Pacific Model 200-D-10-36 Downstroke Self Contained Hydraulic Press</h2>
                    <p class="pd-info__model">Serial No.: <strong>8380 (1978)</strong> — Gib Guided, Dual Cylinder, T-Slotted Bed and Slide</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Bed Area (Nominal)</span>
                            <span class="pd-spec__value">123" L-R x 36" F-B (T-Slotted F-B)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Slide Area (Nominal)</span>
                            <span class="pd-spec__value">123" L-R x 36" F-B (T-Slotted F-B)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Dist. Between Housings</span>
                            <span class="pd-spec__value">L-R</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Stroke of Gib Guided Slide</span>
                            <span class="pd-spec__value">0" — 18" Max.</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Daylight Opening</span>
                            <span class="pd-spec__value">30" Max.</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Max. Upper Die Weight</span>
                            <span class="pd-spec__value">10,000 lbs</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Speeds Approx.</span>
                            <span class="pd-spec__value">187 IPM Fast Closing</span>
                        </div>
                        <div class="pd-spec-sub">
                            <span class="pd-spec-sub__value">89 IPM Slow Close</span>
                            <span class="pd-spec-sub__value">34 IPM Pressing</span>
                            <span class="pd-spec-sub__value">70 IPM Slow Return</span>
                            <span class="pd-spec-sub__value">176 IPM Fast Return</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Power Unit (Top Rear)</span>
                            <span class="pd-spec__value">30 HP 460/3/60 Motor Driving Hydraulic Unit</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">43,000 lbs</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Physical Dimensions</span>
                            <span class="pd-spec__value">13' L-R x 5' F-B x 26' H</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Controls</span>
                            <span class="pd-spec__value">Push Button Operation with Stroke, Pressure and Speed Control. Allen Bradley PLC Added in 2000. Light Curtains.</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__contact">Contact for Pricing</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is a 200 ton hydraulic press used for?</p>
                    <p class="pd-faq__answer">A 200 ton hydraulic press is used for forming, bending, stamping, punching, and assembly operations across manufacturing industries. The Pacific 200-D series is commonly found in automotive, aerospace, appliance, and general metal fabrication shops for medium-duty pressing applications.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What condition is this used Pacific 200-D-10-36 hydraulic press in?</p>
                    <p class="pd-faq__answer">This Pacific Model 200-D-10-36 was manufactured in 1978 (Serial No. 8380). It is a gib guided, dual cylinder press with T-slotted bed and slide. The Allen Bradley PLC controls were upgraded in 2000, and light curtains have been added for operator safety.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What are the main specifications of this 200 ton press?</p>
                    <p class="pd-faq__answer">This press features a 123" x 36" T-slotted bed area, 30" maximum daylight opening, 18" maximum stroke, 34 IPM pressing speed, a 30 HP hydraulic power unit, and weighs approximately 43,000 lbs. Overall dimensions are 13' L-R x 5' F-B x 26' H.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Does Gerrard Group offer shipping and installation?</p>
                    <p class="pd-faq__answer">Yes. Gerrard Group Inc provides full rigging, transportation, and installation services for heavy industrial equipment across the United States, Mexico, and Canada. Contact us at (847) 894-3434 for a quote.</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/300-ton-pacific-hydraulic-press/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        300 Ton Pacific Hydraulic Press
                    </a>
                    <a href="/600-ton-pacific-hydraulic-press/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        600 Ton Pacific Hydraulic Press
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
