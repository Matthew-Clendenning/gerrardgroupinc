---
import Layout from '../layouts/Layout.astro';
import ProductCard from "../components/ProductCard.astro";

import soon1 from '../assets/cooling-tower-1.jpg';
import soon2 from '../assets/pallet-jack-1.png';
import soon3 from '../assets/racking-img-1.png';

import pressOne from "../assets/200-ton-pacific-press-1.jpeg";
import pressTwo from '../assets/300-ton-pacific-press-1.jpeg';
import pressThree from '../assets/600-ton-pacific-press-1.jpeg';

import airCompOne from "../assets/sullair-900-1.jpg";
import airCompTwo from "../assets/atlas-copco-1500-1.jpg";
import airCompThree from "../assets/atlas-copco-1550-1.jpg";
import airCompFour from "../assets/atlas-copco-1600-1.jpg";
---

<Layout title="Used Machinery for Sale - Liquidation & Surplus | Gerrard Group"
    description="Buy surplus industrial equipment at competitive prices. Hydraulic presses, portable air compressors, and more. Browse our used machinery inventory updated regularly."
    canon="https://gerrardgroupinc.com/liquidations/"
    >
    <main class="liq-page">
        <!-- Hero Banner -->
        <section class="liq-hero">
            <div class="liq-hero__inner">
                <h1 class="liq-hero__title">Liquidations & Surplus Equipment</h1>
                <p class="liq-hero__subtitle">Quality used industrial machinery at competitive prices — hydraulic presses, air compressors, and more.</p>
            </div>
        </section>

        <!-- Trust Bar -->
        <section class="liq-trust">
            <div class="liq-trust__inner">
                <div class="liq-trust__item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                    <span>Inspected & Verified</span>
                </div>
                <div class="liq-trust__item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span>Trusted Since 1993</span>
                </div>
                <div class="liq-trust__item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                    <span>Call (847) 894-3434</span>
                </div>
                <div class="liq-trust__item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>Chicago · St. Louis · Spokane</span>
                </div>
            </div>
        </section>

        <!-- Category Filter Bar -->
        <section class="liq-filter">
            <div class="liq-filter__inner">
                <span class="liq-filter__label">Filter:</span>
                <button class="liq-filter__btn liq-filter__btn--active" data-filter="all">All Equipment</button>
                <button class="liq-filter__btn" data-filter="compressor">Air Compressors</button>
                <button class="liq-filter__btn" data-filter="press">Hydraulic Presses</button>
                <button class="liq-filter__btn" data-filter="sold">Sold Items</button>
            </div>
        </section>

        <!-- Product Grid -->
        <section class="liq-grid-section">
            <div class="liq-grid" id="product-grid">
                <div class="liq-grid__item" data-category="compressor">
                    <ProductCard
                        name="Sullair Model 900/1150 Portable Air Compressor"
                        category="Portable Air Compressors"
                        brand="Sullair"
                        imageURL={airCompOne}
                        alt="Sullair Model 900/1150 portable diesel air compressor for sale"
                        href="/sullair-air-compressor-900/"
                        loading="eager"
                        price="199000"
                        condition="Used — 1,601 Hrs"
                    />
                </div>
                <div class="liq-grid__item" data-category="compressor">
                    <ProductCard
                        name="Atlas Copco XRVS 1550 CD Portable Air Compressor"
                        category="Portable Air Compressors"
                        brand="Atlas Copco"
                        imageURL={airCompTwo}
                        alt="Atlas Copco XRVS 1550 CD portable air compressor for sale"
                        href="/atlas-copco-air-compressor-1550-cd/"
                        loading="eager"
                        price="200000"
                        condition="Used — 1,942 Hrs"
                    />
                </div>
                <div class="liq-grid__item" data-category="compressor">
                    <ProductCard
                        name="Atlas Copco XRVS 1550 CD7 Portable Air Compressor"
                        category="Portable Air Compressors"
                        brand="Atlas Copco"
                        imageURL={airCompThree}
                        alt="Atlas Copco XRVS 1550 CD7 portable air compressor for sale"
                        href="/atlas-copco-air-compressor-1550-cd7/"
                        loading="eager"
                        price="200000"
                        condition="Used — 2,827 Hrs"
                    />
                </div>
                <div class="liq-grid__item" data-category="compressor">
                    <ProductCard
                        name="Atlas Copco XAS 1600 CD6 Portable Air Compressor"
                        category="Portable Air Compressors"
                        brand="Atlas Copco"
                        imageURL={airCompFour}
                        alt="Atlas Copco XAS 1600 CD6 portable air compressor for sale"
                        href="/atlas-copco-air-compressor-1600/"
                        loading="eager"
                        price="275000"
                        condition="Used — 2,093 Hrs"
                    />
                </div>
                <div class="liq-grid__item" data-category="press">
                    <ProductCard
                        name="200 Ton Pacific Hydraulic Press"
                        category="Hydraulic Presses"
                        brand="Pacific"
                        imageURL={pressOne}
                        alt="200 ton Pacific downstroke hydraulic press for sale"
                        href="/200-ton-pacific-hydraulic-press/"
                        condition="Used — 1978"
                    />
                </div>
                <div class="liq-grid__item" data-category="press">
                    <ProductCard
                        name="300 Ton Pacific Hydraulic Press"
                        category="Hydraulic Presses"
                        brand="Pacific"
                        imageURL={pressTwo}
                        alt="300 ton Pacific downstroke hydraulic press for sale"
                        href="/300-ton-pacific-hydraulic-press/"
                        condition="Used — 1980"
                    />
                </div>
                <div class="liq-grid__item" data-category="press">
                    <ProductCard
                        name="600 Ton Pacific Hydraulic Press"
                        category="Hydraulic Presses"
                        brand="Pacific"
                        imageURL={pressThree}
                        alt="600 ton Pacific downstroke hydraulic press for sale"
                        href="/600-ton-pacific-hydraulic-press/"
                        condition="Used — 1978"
                    />
                </div>
                <div class="liq-grid__item" data-category="sold">
                    <ProductCard
                        name="Process - Cooling Towers"
                        category="Cooling Equipment"
                        imageURL={soon1}
                        alt="Industrial process cooling towers"
                        href="/cooling-towers/"
                        sold={true}
                        condition="Used"
                    />
                </div>
                <div class="liq-grid__item" data-category="sold">
                    <ProductCard
                        name="Warehouse Pallet Jacks"
                        category="Warehouse Equipment"
                        imageURL={soon2}
                        alt="Collection of warehouse pallet jacks"
                        href="/palletjackdetails/"
                        sold={true}
                        condition="Used"
                    />
                </div>
                <div class="liq-grid__item" data-category="sold">
                    <ProductCard
                        name="Industrial Racking"
                        category="Warehouse Equipment"
                        imageURL={soon3}
                        alt="Industrial warehouse racking system"
                        href="/rackingdetails/"
                        sold={true}
                        condition="Used"
                    />
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="liq-cta">
            <div class="liq-cta__inner">
                <h2 class="liq-cta__title">Don't See What You Need?</h2>
                <p class="liq-cta__text">We source industrial machinery nationwide. Tell us what you're looking for and our team will find it.</p>
                <a href="/contact/" class="liq-cta__btn">Request a Quote</a>
            </div>
        </section>
    </main>
</Layout>

<style is:inline>
    /* ─── Liquidations Page Styles ─── */

    .liq-page {
        background: var(--color-bg, #F9FAFB);
    }

    /* Hero */
    .liq-hero {
        background: linear-gradient(135deg, #0a192f 0%, #055895 50%, #044a7f 100%);
        padding: 64px 24px 56px;
        text-align: center;
    }

    .liq-hero__inner {
        max-width: 720px;
        margin: 0 auto;
    }

    .liq-hero__title {
        font-family: var(--font-heading, "Barlow Condensed", sans-serif);
        font-size: clamp(1.75rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        margin: 0 0 12px;
        letter-spacing: 0.5px;
        line-height: 1.15;
    }

    .liq-hero__subtitle {
        font-family: var(--font-body, "Source Sans 3", sans-serif);
        font-size: clamp(0.95rem, 1.8vw, 1.15rem);
        color: rgba(255, 255, 255, 0.82);
        margin: 0;
        line-height: 1.6;
        max-width: 560px;
        margin-inline: auto;
    }

    /* Trust Bar */
    .liq-trust {
        background: #fff;
        border-bottom: 1px solid var(--color-border, #E5E7EB);
        padding: 16px 24px;
    }

    .liq-trust__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: center;
        gap: 32px;
        flex-wrap: wrap;
    }

    .liq-trust__item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-body, "Source Sans 3", sans-serif);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--color-text-secondary, #6B7280);
        white-space: nowrap;
    }

    .liq-trust__item svg {
        color: var(--color-primary, #055895);
        flex-shrink: 0;
        width: 18px;
        height: 18px;
    }

    /* Filter Bar */
    .liq-filter {
        background: #fff;
        border-bottom: 1px solid var(--color-border, #E5E7EB);
        padding: 14px 24px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .liq-filter__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .liq-filter__label {
        font-family: var(--font-body, "Source Sans 3", sans-serif);
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text-secondary, #6B7280);
        margin-right: 4px;
    }

    .liq-filter__btn {
        font-family: var(--font-body, "Source Sans 3", sans-serif);
        font-size: 0.8rem;
        font-weight: 500;
        padding: 6px 16px;
        border: 1px solid var(--color-border, #E5E7EB);
        border-radius: 20px;
        background: transparent;
        color: var(--color-text-secondary, #6B7280);
        cursor: pointer;
        transition: all var(--transition, 0.25s ease);
    }

    .liq-filter__btn:hover {
        border-color: var(--color-primary, #055895);
        color: var(--color-primary, #055895);
    }

    .liq-filter__btn--active {
        background: var(--color-primary, #055895);
        color: #fff;
        border-color: var(--color-primary, #055895);
    }

    .liq-filter__btn--active:hover {
        background: var(--color-primary-dark, #044a7f);
        border-color: var(--color-primary-dark, #044a7f);
        color: #fff;
    }

    /* Product Grid */
    .liq-grid-section {
        max-width: 1260px;
        margin: 0 auto;
        padding: 40px 24px 48px;
    }

    .liq-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
    }

    .liq-grid__item {
        display: flex;
    }

    .liq-grid__item > * {
        width: 100%;
    }

    .liq-grid__item--hidden {
        display: none;
    }

    /* CTA Section */
    .liq-cta {
        background: linear-gradient(135deg, #0a192f 0%, #1d3557 100%);
        padding: 64px 24px;
        text-align: center;
    }

    .liq-cta__inner {
        max-width: 600px;
        margin: 0 auto;
    }

    .liq-cta__title {
        font-family: var(--font-heading, "Barlow Condensed", sans-serif);
        font-size: clamp(1.5rem, 3.5vw, 2.25rem);
        font-weight: 700;
        color: #fff;
        margin: 0 0 12px;
    }

    .liq-cta__text {
        font-family: var(--font-body, "Source Sans 3", sans-serif);
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.78);
        margin: 0 0 28px;
        line-height: 1.6;
    }

    .liq-cta__btn {
        display: inline-block;
        font-family: var(--font-heading, "Barlow Condensed", sans-serif);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        text-decoration: none;
        padding: 14px 36px;
        background: var(--color-accent, #D97706);
        color: #fff;
        border-radius: var(--radius-sm, 6px);
        transition: background var(--transition, 0.25s ease), transform var(--transition, 0.25s ease);
    }

    .liq-cta__btn:hover {
        background: var(--color-accent-hover, #B45309);
        transform: translateY(-2px);
    }

    /* ─── Responsive ─── */
    @media (max-width: 640px) {
        .liq-hero {
            padding: 40px 16px 36px;
        }

        .liq-trust__inner {
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

        .liq-filter {
            position: static;
        }

        .liq-filter__inner {
            justify-content: center;
        }

        .liq-filter__label {
            width: 100%;
            text-align: center;
        }

        .liq-grid-section {
            padding: 24px 16px 32px;
        }

        .liq-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .liq-cta {
            padding: 48px 16px;
        }
    }

    @media (min-width: 641px) and (max-width: 960px) {
        .liq-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }
    }
</style>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        const buttons = document.querySelectorAll('.liq-filter__btn');
        const items = document.querySelectorAll('.liq-grid__item');

        buttons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                var filter = this.getAttribute('data-filter');

                buttons.forEach(function(b) { b.classList.remove('liq-filter__btn--active'); });
                this.classList.add('liq-filter__btn--active');

                items.forEach(function(item) {
                    var cat = item.getAttribute('data-category');
                    if (filter === 'all' || cat === filter) {
                        item.classList.remove('liq-grid__item--hidden');
                    } else {
                        item.classList.add('liq-grid__item--hidden');
                    }
                });
            });
        });
    });
</script>
