---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides2 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="300 Ton Pacific Hydraulic Press for Sale | Gerrard Group"
    description="Used 300-ton Pacific Model 300-D-10-60 downstroke hydraulic press. Gib guided, dual cylinder, T-slotted bed, Allen Bradley PLC controls. Contact for pricing."
    canon="https://gerrardgroupinc.com/300-ton-pacific-hydraulic-press/"
    jsonLdType="product"
    jsonLdData={{
        name: "300 Ton Pacific Model 300-D-10-60 Hydraulic Press",
        description: "Pacific Model 300-D-10-60 Downstroke Self Contained Hydraulic Press, 300 Ton capacity, Gib Guided, Dual Cylinder, T-Slotted Bed and Slide, Allen Bradley PLC",
        brand: "Pacific",
        category: "Hydraulic Presses",
        price: "0",
        sku: "300-D-10-60-8378",
        condition: "UsedCondition",
        mpn: "300-D-10-60",
        image: "https://gerrardgroupinc.com/images/300-ton-pacific-press-1.webp",
        faq: [
            { question: "What is a 300 ton Pacific hydraulic press used for?", answer: "A 300 ton Pacific hydraulic press is used for heavy-duty forming, stamping, blanking, and deep drawing operations in industries such as aerospace, automotive, metal fabrication, and appliance manufacturing. The 300-ton capacity handles medium to large parts with precision force control." },
            { question: "What is the condition of this used Pacific 300-D-10-60 press?", answer: "This Pacific Model 300-D-10-60 is a used press manufactured in 1978 (Serial No. 8378). It features Allen Bradley PLC controls that were upgraded in 2000, light curtains for operator safety, and is gib guided with dual cylinders for consistent ram travel." },
            { question: "What are the key specifications of this 300 ton hydraulic press?", answer: "Key specs include a 123\" x 60\" T-slotted bed and slide area, 33\" maximum daylight opening, 18\" maximum stroke, pressing speed of 25 IPM, and a 40 HP hydraulic power unit. The press weighs approximately 73,000 lbs." },
            { question: "Can this press be shipped nationwide?", answer: "Yes. Gerrard Group Inc arranges rigging, transportation, and installation of heavy industrial machinery throughout the United States, Mexico, and Canada. Contact us for a shipping and installation quote." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/300-ton-pacific-press-1.webp"
    ogImageAlt="Used 300 Ton Pacific Hydraulic Press for Sale - Gerrard Group"
    >
    <Directory
        title="300 Ton Pacific Model Hydraulic Press"
        page="Hydraulic Presses"
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides2} />
                <article class="pd-info">
                    <h2 class="pd-info__title">300 Ton Pacific Model 300-D-10-60 Downstroke Self Contained Hydraulic Press</h2>
                    <p class="pd-info__model">Serial No.: <strong>8378 (1978)</strong> — Gib Guided, Dual Cylinder, T-Slotted Bed and Slide</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Bed Area (Nominal)</span>
                            <span class="pd-spec__value">123" L-R x 60" F-B (T-Slotted F-B)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Slide Area (Nominal)</span>
                            <span class="pd-spec__value">123" L-R x 60" F-B (T-Slotted F-B)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Dist. Between Housings</span>
                            <span class="pd-spec__value">28" L-R</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Stroke of Gib Guided Slide</span>
                            <span class="pd-spec__value">0" — 18" Max.</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Daylight Opening</span>
                            <span class="pd-spec__value">33" Max.</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Speeds Approx.</span>
                            <span class="pd-spec__value">215 IPM Fast Closing</span>
                        </div>
                        <div class="pd-spec-sub">
                            <span class="pd-spec-sub__value">80 IPM Slow Close</span>
                            <span class="pd-spec-sub__value">25 IPM Pressing</span>
                            <span class="pd-spec-sub__value">48 IPM Slow Return</span>
                            <span class="pd-spec-sub__value">132 IPM Fast Return</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Power Unit (Top Rear)</span>
                            <span class="pd-spec__value">40 HP 460/3/60 Motor Driving Hydraulic Unit</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">73,000 lbs</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Physical Dimensions</span>
                            <span class="pd-spec__value">L-R x 5' F-B x H</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Controls</span>
                            <span class="pd-spec__value">Push Button Operation with Stroke, Pressure and Speed Control. Allen Bradley PLC Added in 2000. Light Curtains.</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__contact">Contact for Pricing</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is a 300 ton Pacific hydraulic press used for?</p>
                    <p class="pd-faq__answer">A 300 ton Pacific hydraulic press is used for heavy-duty forming, stamping, blanking, and deep drawing operations in industries such as aerospace, automotive, metal fabrication, and appliance manufacturing. The 300-ton capacity handles medium to large parts with precision force control.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the condition of this used Pacific 300-D-10-60 press?</p>
                    <p class="pd-faq__answer">This Pacific Model 300-D-10-60 is a used press manufactured in 1978 (Serial No. 8378). It features Allen Bradley PLC controls that were upgraded in 2000, light curtains for operator safety, and is gib guided with dual cylinders for consistent ram travel.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What are the key specifications of this 300 ton hydraulic press?</p>
                    <p class="pd-faq__answer">Key specs include a 123" x 60" T-slotted bed and slide area, 33" maximum daylight opening, 18" maximum stroke, pressing speed of 25 IPM, and a 40 HP hydraulic power unit. The press weighs approximately 73,000 lbs.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Can this press be shipped nationwide?</p>
                    <p class="pd-faq__answer">Yes. Gerrard Group Inc arranges rigging, transportation, and installation of heavy industrial machinery throughout the United States, Mexico, and Canada. Contact us for a shipping and installation quote.</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/200-ton-pacific-hydraulic-press/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        200 Ton Pacific Hydraulic Press
                    </a>
                    <a href="/600-ton-pacific-hydraulic-press/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        600 Ton Pacific Hydraulic Press
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
