---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides8 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="Atlas Copco XAS 1600 CD6 Air Compressor for Sale | Gerrard"
    description="Used 2010 Atlas Copco XAS 1600 CD6 high-volume diesel portable air compressor. 1500 CFM at 125 PSI, Cat diesel engine, 3,011 hours. Sale price $40,500."
    canon="https://gerrardgroupinc.com/atlas-copco-air-compressor-1600/"
    jsonLdType="product"
    jsonLdData={{
        name: "Atlas Copco XAS 1600 CD6 Portable Air Compressor",
        description: "2010 Atlas Copco XAS 1600 CD6 High Volume Medium Pressure Diesel Portable Air Compressor, 1500 CFM at 125 PSI, Cat Diesel Engine, 3011 hours",
        brand: "Atlas Copco",
        category: "Portable Air Compressors",
        price: "40500",
        sku: "XAS-1600-CD6",
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/atlas-copco-1600-1.jpg",
        faq: [
            { question: "What is the Atlas Copco XAS 1600 CD6 used for?", answer: "The Atlas Copco XAS 1600 CD6 is a high-volume, medium-pressure portable diesel air compressor used for sandblasting, pneumatic tool operation, pipeline purging, and general industrial construction. Its 1500 CFM at 125 PSI output is ideal for applications requiring large volumes of air at moderate pressure." },
            { question: "How does the XAS 1600 differ from the XRVS 1550 models?", answer: "The XAS 1600 CD6 is a high-volume, medium-pressure compressor (1500 CFM at 125 PSI), while the XRVS 1550 models are high-pressure units (1544 CFM at 365 PSI). The XAS 1600 is better suited for sandblasting and pneumatic tools, while the XRVS 1550 excels at pipeline testing and well drilling." },
            { question: "How many hours are on this compressor?", answer: "This 2010 Atlas Copco XAS 1600 CD6 has 3,011 hours. It is powered by a Cat diesel engine with a 244-gallon fuel tank, after cooler, water separator, and electric block heater." },
            { question: "Is this unit highway towable?", answer: "This unit is on a two-axle jobsite-style (non-highway) frame. It is designed for on-site mobility rather than highway towing. Contact Gerrard Group for transportation options." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/atlas-copco-1600-1.jpg"
    ogImageAlt="Used Atlas Copco XAS 1600 CD6 Portable Air Compressor for Sale - Gerrard Group"
    >
    <Directory
        title="Atlas Copco XAS 1600 CD6 Portable Air Compressor"
        page=""
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides8} />
                <article class="pd-info">
                    <h2 class="pd-info__title">Atlas Copco XAS 1600 CD6 High Volume Medium Pressure Diesel Portable Air Compressor</h2>
                    <p class="pd-info__model">Model: <strong>XAS 1600 CD6</strong> — New 2010 (3,011 Hours)</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Capacity</span>
                            <span class="pd-spec__value">1500 CFM @ 125 PSI (Norm.)<br>1370 CFM @ 150 PSI (Max.)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Fuel Capacity</span>
                            <span class="pd-spec__value">244 Gallon</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Frame</span>
                            <span class="pd-spec__value">Two Axle — Jobsite Style (Non Hwy.)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Equipped With</span>
                            <span class="pd-spec__value">Cat Diesel Engine, After Cooler, Water Separator, Electric Block Heater</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">12,400 lbs</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__original">$42,500.00</p>
                        <p class="pd-pricing__sale">$40,500.00</p>
                        <p class="pd-pricing__label">Special Sale Price</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the Atlas Copco XAS 1600 CD6 used for?</p>
                    <p class="pd-faq__answer">The Atlas Copco XAS 1600 CD6 is a high-volume, medium-pressure portable diesel air compressor used for sandblasting, pneumatic tool operation, pipeline purging, and general industrial construction. Its 1500 CFM at 125 PSI output is ideal for applications requiring large volumes of air at moderate pressure.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How does the XAS 1600 differ from the XRVS 1550 models?</p>
                    <p class="pd-faq__answer">The XAS 1600 CD6 is a high-volume, medium-pressure compressor (1500 CFM at 125 PSI), while the XRVS 1550 models are high-pressure units (1544 CFM at 365 PSI). The XAS 1600 is better suited for sandblasting and pneumatic tools, while the XRVS 1550 excels at pipeline testing and well drilling.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How many hours are on this compressor?</p>
                    <p class="pd-faq__answer">This 2010 Atlas Copco XAS 1600 CD6 has 3,011 hours. It is powered by a Cat diesel engine with a 244-gallon fuel tank, after cooler, water separator, and electric block heater.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Is this unit highway towable?</p>
                    <p class="pd-faq__answer">This unit is on a two-axle jobsite-style (non-highway) frame. It is designed for on-site mobility rather than highway towing. Contact Gerrard Group for transportation options.</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/atlas-copco-air-compressor-1550-cd/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XRVS 1550 CD Air Compressor
                    </a>
                    <a href="/atlas-copco-air-compressor-1550-cd7/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XRVS 1550 CD7 Air Compressor
                    </a>
                    <a href="/sullair-air-compressor-900/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Sullair 900/1150 Air Compressor
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
