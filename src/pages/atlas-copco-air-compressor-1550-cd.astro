---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides7 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="Atlas Copco XRVS 1550 CD Air Compressor for Sale | Gerrard"
    description="Used 2014 Atlas Copco XRVS 1550 CD high-pressure diesel portable air compressor. 1544 CFM at 365 PSI, Cat diesel engine, only 1,942 hours. Sale price $200,000."
    canon="https://gerrardgroupinc.com/atlas-copco-air-compressor-1550-cd/"
    jsonLdType="product"
    jsonLdData={{
        name: "Atlas Copco XRVS 1550 CD Portable Air Compressor",
        description: "2014 Atlas Copco XRVS 1550 CD High Pressure Diesel Portable Air Compressor, 1544 CFM at 365 PSI, Cat Diesel Engine, only 1942 hours",
        brand: "Atlas Copco",
        category: "Portable Air Compressors",
        price: "200000",
        sku: "XRVS-1550-CD",
        condition: "UsedCondition",
        image: "https://gerrardgroupinc.com/images/atlas-copco-1500-1.jpg",
        faq: [
            { question: "What is the Atlas Copco XRVS 1550 CD used for?", answer: "The Atlas Copco XRVS 1550 CD is a high-pressure portable diesel air compressor used in pipeline testing, well drilling, sandblasting, mining operations, and industrial construction. Its 1544 CFM at 365 PSI output makes it suitable for demanding jobsite air supply needs." },
            { question: "How many hours are on this compressor?", answer: "This 2014 Atlas Copco XRVS 1550 CD has only 1,942 hours, which is considered low usage for a compressor of this age. It is powered by a Cat diesel engine and includes an after cooler, water separator, and electric block heater." },
            { question: "What is the fuel capacity and portability of this unit?", answer: "This unit has a 240-gallon fuel tank and is mounted on a tandem axle frame with electric brakes, making it highway towable. The GVWR is 8,095 kg and the GAWR is 9,070 kg." },
            { question: "Does Gerrard Group offer financing or delivery?", answer: "Contact Gerrard Group Inc at (847) 894-3434 to discuss pricing, financing options, and delivery arrangements. We ship heavy industrial equipment throughout the United States, Mexico, and Canada." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/atlas-copco-1500-1.jpg"
    ogImageAlt="Used Atlas Copco XRVS 1550 CD Portable Air Compressor for Sale - Gerrard Group"
    >
    <Directory
        title="Atlas Copco XRVS 1550 CD Portable Air Compressor"
        page=""
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slides7} />
                <article class="pd-info">
                    <h2 class="pd-info__title">Atlas Copco XRVS 1550 CD High Pressure Diesel Portable Air Compressor</h2>
                    <p class="pd-info__model">Model: <strong>XRVS 1550 CD</strong> — New 2014 (Only 1,942 Hours)</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Capacity</span>
                            <span class="pd-spec__value">1544 CFM @ 365 PSI (Norm.)<br>1350 CFM @ 506 PSI (Max.)</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Fuel Capacity</span>
                            <span class="pd-spec__value">240 Gallon</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Frame</span>
                            <span class="pd-spec__value">Tandem Axle with Electric Brakes</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Equipped With</span>
                            <span class="pd-spec__value">Cat Diesel Engine, After Cooler, Water Separator, Electric Block Heater</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Weight Approx.</span>
                            <span class="pd-spec__value">GVWR: 8,095 Kg<br>GAWR: 9,070 Kg</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__original">$279,000.00</p>
                        <p class="pd-pricing__sale">$200,000.00</p>
                        <p class="pd-pricing__label">Special Sale Price</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the Atlas Copco XRVS 1550 CD used for?</p>
                    <p class="pd-faq__answer">The Atlas Copco XRVS 1550 CD is a high-pressure portable diesel air compressor used in pipeline testing, well drilling, sandblasting, mining operations, and industrial construction. Its 1544 CFM at 365 PSI output makes it suitable for demanding jobsite air supply needs.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How many hours are on this compressor?</p>
                    <p class="pd-faq__answer">This 2014 Atlas Copco XRVS 1550 CD has only 1,942 hours, which is considered low usage for a compressor of this age. It is powered by a Cat diesel engine and includes an after cooler, water separator, and electric block heater.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the fuel capacity and portability of this unit?</p>
                    <p class="pd-faq__answer">This unit has a 240-gallon fuel tank and is mounted on a tandem axle frame with electric brakes, making it highway towable. The GVWR is 8,095 kg and the GAWR is 9,070 kg.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Does Gerrard Group offer financing or delivery?</p>
                    <p class="pd-faq__answer">Contact Gerrard Group Inc at (847) 894-3434 to discuss pricing, financing options, and delivery arrangements. We ship heavy industrial equipment throughout the United States, Mexico, and Canada.</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/atlas-copco-air-compressor-1550-cd7/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XRVS 1550 CD7 Air Compressor
                    </a>
                    <a href="/atlas-copco-air-compressor-1600/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Atlas Copco XAS 1600 CD6 Air Compressor
                    </a>
                    <a href="/sullair-air-compressor-900/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Sullair 900/1150 Air Compressor
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
