---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slidesWelder } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout
    title="Miller Phoenix 456 Welder for Sale | Gerrard Group"
    description="Used Miller Phoenix 456 multiprocess welder for sale. MIG, TIG, Stick, and Flux-Cored capable power source from Hillsdale Fabricator liquidation. Contact Gerrard Group for pricing."
    canon="https://gerrardgroupinc.com/miller-phoenix-456/"
    jsonLdType="product"
    jsonLdData={{
        name: "Miller Phoenix 456 Multiprocess Welder",
        description: "Used Miller Phoenix 456 multiprocess welder. 1 unit available from Hillsdale Fabricator liquidation.",
        brand: "Miller",
        category: "Welding Equipment",
        condition: "UsedCondition",
        mpn: "Phoenix 456",
        offerCount: 1,
        image: "https://gerrardgroupinc.com/images/miller-welder-1.webp",
        faq: [
            { question: "What is the Miller Phoenix 456?", answer: "The Miller Phoenix 456 is a rugged multiprocess welding power source designed for heavy industrial use. It supports MIG, TIG, Stick, and Flux-Cored welding processes and is known for its reliability in demanding fabrication environments." },
            { question: "How many Miller Phoenix 456 units are available?", answer: "Gerrard Group currently has 1 Miller Phoenix 456 welder available from a Hillsdale Fabricator liquidation." },
            { question: "Can Gerrard Group ship this welder?", answer: "Yes. Gerrard Group Inc provides rigging, transportation, and installation services for industrial equipment throughout the United States, Mexico, and Canada. Contact us at (847) 894-3434 for a shipping quote." }
        ]
    }}
    ogType="product"
    ogImage="https://gerrardgroupinc.com/images/miller-welder-1.webp"
    ogImageAlt="Used Miller Phoenix 456 Welder for Sale - Gerrard Group"
    >
    <Directory
        title="Miller Phoenix 456 Welder"
        page="Welding Equipment"
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-layout">
                <Carousel client:load data={slidesWelder} />
                <article class="pd-info">
                    <h2 class="pd-info__title">Miller Phoenix 456 Multiprocess Welder</h2>
                    <p class="pd-info__model"><strong>1 Unit Available</strong> — Hillsdale Fabricator Liquidation</p>
                    <hr class="pd-info__divider">
                    <div class="pd-specs">
                        <div class="pd-spec">
                            <span class="pd-spec__label">Brand</span>
                            <span class="pd-spec__value">Miller Electric</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Model</span>
                            <span class="pd-spec__value">Phoenix 456</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Type</span>
                            <span class="pd-spec__value">Multiprocess Welder</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Processes</span>
                            <span class="pd-spec__value">MIG / TIG / Stick / Flux-Cored</span>
                        </div>
                        <div class="pd-spec">
                            <span class="pd-spec__label">Quantity Available</span>
                            <span class="pd-spec__value">1</span>
                        </div>
                    </div>
                    <div class="pd-pricing">
                        <p class="pd-pricing__sale">Contact for Pricing</p>
                    </div>
                    <div class="pd-actions">
                        <a href="/contact/" class="pd-btn pd-btn--primary">Request a Quote</a>
                        <a href="tel:+18478943434" class="pd-btn pd-btn--secondary">Call (847) 894-3434</a>
                    </div>
                </article>
            </div>
            <section class="pd-faq">
                <h3 class="pd-faq__title">Frequently Asked Questions</h3>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">What is the Miller Phoenix 456?</p>
                    <p class="pd-faq__answer">The Miller Phoenix 456 is a rugged multiprocess welding power source designed for heavy industrial use. It supports MIG, TIG, Stick, and Flux-Cored welding processes and is known for its reliability in demanding fabrication environments.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">How many Miller Phoenix 456 units are available?</p>
                    <p class="pd-faq__answer">Gerrard Group currently has 1 Miller Phoenix 456 welder available from a Hillsdale Fabricator liquidation.</p>
                </div>
                <div class="pd-faq__item">
                    <p class="pd-faq__question">Can Gerrard Group ship this welder?</p>
                    <p class="pd-faq__answer">Yes. Gerrard Group Inc provides rigging, transportation, and installation services for industrial equipment throughout the United States, Mexico, and Canada. Contact us at (847) 894-3434 for a shipping quote.</p>
                </div>
            </section>
            <section class="pd-related">
                <h3 class="pd-related__title">Related Equipment</h3>
                <div class="pd-related__list">
                    <a href="/miller-xmt-450/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Miller XMT 450 Welder
                    </a>
                    <a href="/miller-456-xmt/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Miller 456 XMT Welder
                    </a>
                    <a href="/miller-invision-456p/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Miller Invision 456P Welder
                    </a>
                    <a href="/miller-xmt-350/" class="pd-related__link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Miller XMT 350 Welder
                    </a>
                </div>
            </section>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
