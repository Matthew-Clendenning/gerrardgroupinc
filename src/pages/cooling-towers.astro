---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/MachineDirectory.astro";
import { Carousel } from "../components/Carousel.jsx";
import { slides4 } from "../data/carouselData.json";
import "../styles/product-detail.css";
---

<Layout title="Industrial Cooling Towers - SOLD | Gerrard Group Inc"
    description="This industrial process cooling tower has been sold. Browse our current surplus machinery inventory for available equipment including air compressors and hydraulic presses."
    canon="https://gerrardgroupinc.com/cooling-towers/"
    jsonLdType="product"
    jsonLdData={{
        name: "Industrial Process Cooling Towers",
        description: "Industrial process cooling towers - previously available through Gerrard Group Inc",
        brand: "Various",
        category: "Cooling Equipment",
        price: "0",
        sold: true,
        condition: "UsedCondition"
    }}
    >
    <Directory
        title="Process - Cooling Towers"
        page="Cooling Towers"
        page2="Machine Details"
        href="/liquidations"
    />
    <main class="pd-page">
        <div class="pd-content">
            <div class="pd-sold-layout">
                <Carousel client:load data={slides4} />
                <span class="pd-sold-badge">Sold</span>
                <p class="pd-sold-text">This item has been sold. Browse our <a href="/liquidations/">current inventory</a> for available equipment.</p>
            </div>
            <a href="/liquidations/" class="pd-back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 13l-5-5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back to All Equipment
            </a>
        </div>
    </main>
</Layout>
