---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';
//import { ViewTransitions } from 'astro:transitions';

export interface Props {
    title: string;
	description: string;
	canon: string;
	jsonLdType?: string;
	jsonLdData?: Record<string, any>;
	ogType?: string;
	ogImage?: string;
	ogImageWidth?: string;
	ogImageHeight?: string;
	ogImageAlt?: string;
	preloadImage?: string;
}

const { title, description, canon, jsonLdType, jsonLdData, ogType = "website", ogImage: ogImageProp, ogImageWidth, ogImageHeight, ogImageAlt, preloadImage } = Astro.props as Props;
const defaultOgImage = new URL('/images/dans%20logo%20copy6.png', Astro.site || 'https://gerrardgroupinc.com').href;
const ogImage = ogImageProp || defaultOgImage;
const finalOgImageWidth = ogImageWidth || (ogImageProp ? "1200" : "500");
const finalOgImageHeight = ogImageHeight || (ogImageProp ? "630" : "139");
const finalOgImageAlt = ogImageAlt || `${title} - Gerrard Group Inc`;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{title}</title>
		<meta name="description" content={description}>
		<meta name="robots" content="index, follow">
		<link rel="canonical" href={canon}>

		<!-- Preconnect hints -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="dns-prefetch" href="https://fonts.googleapis.com">

		<!-- Google Fonts: Barlow Condensed (headings) + Source Sans 3 (body) -->
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

		{preloadImage && <link rel="preload" as="image" href={preloadImage}>}

		<!-- Favicons -->
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
		<meta name="msapplication-TileColor" content="#055895">
		<meta name="theme-color" content="#055895">
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Open Graph -->
		<meta property="og:site_name" content="Gerrard Group Inc">
		<meta property="og:title" content={title}>
		<meta property="og:description" content={description}>
		<meta property="og:url" content={canon}>
		<meta property="og:type" content={ogType}>
		<meta property="og:locale" content="en_US">
		<meta property="og:image" content={ogImage}>
		<meta property="og:image:width" content={finalOgImageWidth}>
		<meta property="og:image:height" content={finalOgImageHeight}>
		<meta property="og:image:alt" content={finalOgImageAlt}>

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:title" content={title}>
		<meta name="twitter:description" content={description}>
		<meta name="twitter:image" content={ogImage}>
		<meta name="twitter:image:alt" content={finalOgImageAlt}>

		<!-- Schema.org itemprop -->
		<meta itemprop="name" content={title}>
		<meta itemprop="description" content={description}>
		<meta itemprop="url" content={canon}>

		<meta name="format-detection" content="telephone=no">
		<meta name="apple-mobile-web-app-title" content="Gerrard Group Inc">
		<meta name="application-name" content="Gerrard Group Inc">
		<meta name="google-site-verification" content="-sDys0daq54OU4V_RvMtLAo9ktYFLSXxlG8nyHmzRHQ" />
		<!-- BING_VERIFICATION: Replace content value with your Bing Webmaster Tools verification code -->
		<meta name="msvalidate.01" content="BING_VERIFICATION_CODE_HERE" />
		<!-- YANDEX_VERIFICATION: Replace content value with your Yandex verification code (optional) -->
		<meta name="yandex-verification" content="YANDEX_VERIFICATION_CODE_HERE" />
		<Seo type={jsonLdType} data={jsonLdData} />
		<script src="../scripts/BTT.js"></script>
	</head>
	<body id="transition">
		<Header />
		<slot />
		<Footer />
    </body>
</html>